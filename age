<!DOCTYPE html>
<html>
<head>
    <title>Age Calculator</title>
</head>
<body>

<h2>Age Calculator</h2>

<form method="post">
    Enter Birth Date:
    <input type="date" name="dob" required>
    <input type="submit" value="Calculate">
</form>

<?php

if($_POST)
{
    $birth = new DateTime($_POST["dob"]);
    $today = new DateTime();

    $age = $today->diff($birth);

    echo "<h3>";
    echo $age->y . " Years ";
    echo $age->m . " Months ";
    echo $age->d . " Days";
    echo "</h3>";
}

?>

