    echo "<p><strong>State:</strong> " . $_POST['state'] . "</p>";

    echo "<p><strong>Gender:</strong> " . $_POST['gender'] . "</p>";

    echo "<p><strong>Hobbies:</strong> " . implode(", ", $_POST['hobbies']) . "</p>";

